# Application
APP_ENV=development
PORT=8080

# Auth: when true, RequireTenant accepts an X-Tenant-ID header as a fallback
# whenever no bearer token is present. Keep this ON locally so seed.sh and
# curl-driven workflows keep functioning without a login flow; flip it OFF
# (the code default) in any production-like environment so only logged-in
# sessions can touch tenant-scoped routes.
ALLOW_TENANT_HEADER_AUTH=true

# Database
POSTGRES_USER=fielddesk
POSTGRES_PASSWORD=fielddesk
POSTGRES_DB=fielddesk
DATABASE_URL=postgres://fielddesk:fielddesk@postgres:5432/fielddesk?sslmode=disable

# Object storage (MinIO local, S3-compatible)
S3_ENDPOINT=minio:9000
S3_REGION=us-east-1
S3_BUCKET=fielddesk
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_USE_SSL=false
# URL the *browser* uses to upload directly (host port, not container hostname).
S3_PUBLIC_ENDPOINT=http://localhost:9000

# Web -> API. If 8080 is taken on your host, override API_HOST_PORT (set
# below) and update this URL to match — the container port stays 8080.
NEXT_PUBLIC_API_URL=http://localhost:8080

# Host port the API binds to. Override when another project on the same
# machine is already using 8080. The container always listens on 8080;
# this only changes the host-side mapping.
API_HOST_PORT=8080

# Voice note upload constraints
VOICE_NOTE_MAX_BYTES=52428800
PRESIGN_TTL_SECONDS=900

# AI providers
# TRANSCRIPTION_PROVIDER: stub | openai
TRANSCRIPTION_PROVIDER=stub
TRANSCRIPTION_MODEL=whisper-1
# EXTRACTION_PROVIDER: stub | openai
EXTRACTION_PROVIDER=stub
EXTRACTION_MODEL=gpt-4o-mini
EXTRACTION_CONFIDENCE_THRESHOLD=0.7
LLM_PROVIDER=openai
EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Live voice assistant (Gemini Live). The feature stays hidden unless
# GEMINI_API_KEY is set and VOICE_ENABLED is true.
GEMINI_API_KEY=
VOICE_ENABLED=true
VOICE_MODEL=models/gemini-2.5-flash-native-audio-preview-09-2025
VOICE_NAME=Kore

# Reranking is opt-in. 'none' (default) skips reranking entirely; the
# RRF-fused hybrid_search results flow through unchanged.
# 'voyage' (recommended) uses Voyage rerank-2.5-lite, currently 25x
# cheaper than Cohere per call ($0.02/M tokens vs $2/1K calls) with a
# 200M-token free tier per account.
# 'cohere' wires Cohere Rerank v3.5.
# RERANK_OVERREQUEST controls how many chunks hybrid_search returns
# before reranking down to top_k; larger values give the reranker more
# candidates to choose from at higher cost.
# RERANK_MODEL: default is auto-mapped to the provider's cheapest sensible
# model (rerank-2.5-lite for voyage, rerank-v3.5 for cohere).
RERANK_PROVIDER=none
RERANK_MODEL=rerank-2.5-lite
RERANK_OVERREQUEST=20
COHERE_API_KEY=
VOYAGE_API_KEY=

# Worker tuning
WORKER_POLL_INTERVAL_SECONDS=2
WORKER_MAX_CONCURRENT_JOBS=4
WORKER_MAX_RETRIES=5

# Phase 4c eval sidecar (opt-in: `docker compose --profile evals up evals`).
# EVALS_TENANT_ID is required when the profile is enabled. EVALS_KIND is
# one of rag | extraction | all. EVALS_INTERVAL_SECONDS controls the sleep
# between runs (86400 = once a day; drop to 3600 for hourly while debugging).
EVALS_TENANT_ID=
EVALS_KIND=all
EVALS_INTERVAL_SECONDS=86400
